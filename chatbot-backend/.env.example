# Example Environment Configuration

# OLLAMA LLM Configuration (FREE - No API key needed!)
# Installation:
# 1. Download: https://ollama.ai
# 2. Run: ollama run llama2
# 3. Backend automatically connects to http://localhost:11434
#
# Models available:
# - llama2 (recommended - good balance)
# - mistral (fast)
# - neural-chat (chat optimized)
# - dolphin-mixtral (more capable)
OLLAMA_MODEL=llama2

# NOTE: No OPENAI_API_KEY needed!

# Local Development
SERVER_PORT=8080
ENVIRONMENT=development

# Database (post-MVP)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=saarthi_chatbot
# DB_USER=chatbot_user
# DB_PASSWORD=secure_password_here

# Logging
LOG_LEVEL=DEBUG

# Sessions
SESSION_TIMEOUT_MINUTES=30
MAX_CONVERSATION_HISTORY=10

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4321,http://localhost:3000,http://localhost:5173

# Admin/Monitoring
ADMIN_EMAIL=admin@example.com
ENABLE_CRISIS_LOGGING=true
CRISIS_ALERT_EMAIL=crisis-team@example.com
